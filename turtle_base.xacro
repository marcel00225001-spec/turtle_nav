<?xml version="1.0"?>
<robot  xmlns:xacro="http://www.ros.org/wiki/xacro">

        
        <xacro:property name="base_length" value="0.18"/>
        <xacro:property name="base_width" value="0.18"/>
        <xacro:property name="base_height" value="0.011"/>
        <xacro:property name="base_mass" value="1.2"/>
        <xacro:property name="floor1_length" value="0.18"/>
        <xacro:property name="floor1_width" value="0.18"/>
        <xacro:property name="floor1_height" value="0.011"/>
        <xacro:property name="floor1_mass" value="0.4"/>
        <xacro:property name="floor2_length" value="0.18"/>
        <xacro:property name="floor2_width" value="0.18"/>
        <xacro:property name="floor2_height" value="0.011"/>
        <xacro:property name="floor2_mass" value="0.3"/>
        <xacro:property name="floor3_length" value="0.18"/>
        <xacro:property name="floor3_width" value="0.18"/>
        <xacro:property name="floor3_height" value="0.011"/>
        <xacro:property name="floor3_mass" value="0.2"/>
        <xacro:property name="wheel_radius" value="0.033"/>
        <xacro:property name="wheel_length" value="0.02"/>
        <xacro:property name="wheel_mass" value="0.15"/>
        <xacro:property name="caster_wheel_radius" value="0.01"/>
        <xacro:property name="caster_wheel_mass" value="0.05"/>

        <link name="base_link">
            <visual>
                <geometry>
                    <box size="${base_length} ${base_width} ${base_height}"/>
                </geometry>
                <origin xyz="0 0 ${base_height/2}" rpy="0 0 0"/>
                <material name="grey"/>
            </visual>
            <collision>
                <geometry>
                    <box size="${base_length} ${base_width} ${base_height}"/>
                </geometry>
                <origin xyz="0 0 ${base_height/2}" rpy="0 0 0"/>
            </collision>
            <xacro:box_inertia mass="${base_mass}" length="${2*base_length}" width="${2*base_width}" height="${2*base_height}" xyz="0 0 0" rpy="0 0 0"/>
        </link>
        
        <link name="base_footprint"/>
        

        
        <link name="floor1_link">
            <visual>
                <geometry>
                    <box size="${floor1_length} ${floor1_width} ${floor1_height}"/>
                </geometry>
                <origin xyz="0 0 0" rpy="0 0 0"/>
                <material name="grey"/>
            </visual>
            <collision>
                <geometry>
                    <box size="${floor1_length} ${floor1_width} ${floor1_height}"/>
                </geometry>
                <origin xyz="0 0 0" rpy="0 0 0"/>
            </collision>
            <xacro:box_inertia mass="${floor1_mass}" length="${2*floor1_length}" width="${2*floor1_width}" height="${2*floor1_height}" xyz="0 0 -${floor1_height/2}" rpy="0 0 0"/>
        </link>
        
        <link name="floor2_link">
            <visual>
                <geometry>
                    <box size="${floor2_length} ${floor2_width} ${floor2_height}"/>
                </geometry>
                <origin xyz="0 0 0" rpy="0 0 0"/>
                <material name="grey"/>
            </visual>
            <collision>
                <geometry>
                    <box size="${floor2_length} ${floor2_width} ${floor2_height}"/>
                </geometry>
                <origin xyz="0 0 0" rpy="0 0 0"/>
            </collision>
            <xacro:box_inertia mass="${floor2_mass}" length="${2*floor2_length}" width="${2*floor2_width}" height="${2*floor2_height}" xyz="0 0 -${floor2_height/2}" rpy="0 0 0"/>
        </link>
        <!--
        <link name="floor3_link">
            <visual>
                <geometry>
                    <box size="${floor3_length} ${floor3_width} ${floor3_height}"/>
                </geometry>
                <origin xyz="0 0 0" rpy="0 0 0"/>
                <material name="grey"/>
            </visual>
            <collision>
                <geometry>
                    <box size="${floor3_length} ${floor3_width} ${floor3_height}"/>
                </geometry>
                <origin xyz="0 0 0" rpy="0 0 0"/>
            </collision>
            <xacro:box_inertia mass="${floor3_mass}" length="${floor3_length}" width="${floor3_width}" height="${floor3_height}" xyz="0 0 -${floor3_height/2}" rpy="0 0 0"/>
        </link>
        -->
        <link name="right_wheel_link">
            <visual>
                <geometry>
                    <cylinder length="${wheel_length}" radius="${wheel_radius}"/>
                </geometry>
                <origin xyz="0 0 0" rpy="${pi/2} 0 0"/>
                <material name="black"/>
            </visual>
            <collision>
                <geometry>
                    <cylinder length="${wheel_length}" radius="${wheel_radius}"/>
                </geometry>
                <origin xyz="0 0 0" rpy="${pi/2} 0 0"/>
            </collision>
            <xacro:cylinder_inertia m="${wheel_mass}" l="${2*wheel_length}" r="${2*wheel_radius}" xyz="0 0 0" rpy="${pi/2} 0 0"/>
        </link>

        <link name="left_wheel_link">
            <visual>
                <geometry>
                    <cylinder length="${wheel_length}" radius="${wheel_radius}"/>
                </geometry>
                <origin xyz="0 0 0" rpy="${pi/2} 0 0"/>
                <material name="black"/>
            </visual>
            <collision>
                <geometry>
                    <cylinder length="${wheel_length}" radius="${wheel_radius}"/>
                </geometry>
                <origin xyz="0 0 0" rpy="${pi/2} 0 0"/>
            </collision>
            <xacro:cylinder_inertia m="${wheel_mass}" l="${2*wheel_length}" r="${2*wheel_radius}" xyz="0 0 0" rpy="${pi/2} 0 0"/>
        </link>

        <link name="caster_wheel_link">
            <visual>
                <geometry>
                    <sphere radius="${wheel_radius/2.0}"/>
                </geometry>
                <origin xyz="0 0 0" rpy="0 0 0"/>
                <material name="black"/>
            </visual>
            <collision>
                <geometry>
                    <sphere radius="${wheel_radius/2.0}"/>
                </geometry>
                <origin xyz="0 0 0" rpy="0 0 0"/>
            </collision>
            <xacro:sphere_inertia m="${caster_wheel_mass}" r="${2*wheel_radius/2.0}" xyz="0 0 0" rpy="0 0 0"/>
        </link>

        <xacro:macro name="standoff" params="prefix radius length mass xyz rpy">
            <link name="${prefix}_standoff_link">
                <visual>
                    <geometry>
                        <cylinder length="${length}" radius="${radius}"/>
                    </geometry>
                    <origin xyz="${xyz}" rpy="${rpy}"/>
                    <material name="black"/>
                </visual>
                <collision>
                    <geometry>
                        <cylinder length="${length}" radius="${radius}"/>
                    </geometry>
                    <origin xyz="${xyz}" rpy="${rpy}"/>
                </collision>
                <xacro:cylinder_inertia m="${mass}" l="${2*length}" r="${2*radius}" xyz="${xyz}" rpy="${rpy}"/>
            </link>
        </xacro:macro>
        <xacro:standoff prefix="right_wheel_1" radius="0.008" length="0.05" mass="0.002" xyz="0 0 0" rpy="0 0 0"/>
        <xacro:standoff prefix="left_wheel_1" radius="0.008" length="0.05" mass="0.002" xyz="0 0 0" rpy="0 0 0"/>
        <xacro:standoff prefix="caster_wheel_1" radius="0.008" length="0.05" mass="0.002" xyz="0 0 0" rpy="0 0 0"/>
        <xacro:standoff prefix="right_wheel_2" radius="0.008" length="0.05" mass="0.002" xyz="0 0 0" rpy="0 0 0"/>
        <xacro:standoff prefix="left_wheel_2" radius="0.008" length="0.05" mass="0.002" xyz="0 0 0" rpy="0 0 0"/>
        <xacro:standoff prefix="caster_wheel_2" radius="0.008" length="0.05" mass="0.002" xyz="0 0 0" rpy="0 0 0"/>
        <!--
        <xacro:standoff prefix="right_wheel_3" radius="0.008" length="0.05" mass="0.002" xyz="0 0 0" rpy="0 0 0"/>
        <xacro:standoff prefix="left_wheel_3" radius="0.008" length="0.05" mass="0.002" xyz="0 0 0" rpy="0 0 0"/>
        <xacro:standoff prefix="caster_wheel_3" radius="0.008" length="0.05" mass="0.002" xyz="0 0 0" rpy="0 0 0"/>
        -->
        <joint name="footprint_to_base" type="fixed">
            <parent link="base_footprint"/>
            <child link="base_link"/>
            <origin xyz="0 0 ${wheel_radius}" rpy="0 0 0"/>
        </joint>

        
        <joint name="base_to_right_wheel_1" type="fixed">
            <parent link="base_link"/>
            <child link="right_wheel_1_standoff_link"/>
            <origin xyz="${-base_length/4.0} ${-(base_width )/3.0} ${0.025 + base_height}" rpy="0 0 0"/>
        </joint>

        <joint name="base_to_left_wheel_1" type="fixed">
            <parent link="base_link"/>
            <child link="left_wheel_1_standoff_link"/>
            <origin xyz="${-base_length/4.0} ${(base_width )/3.0} ${0.025 + base_height}" rpy="0 0 0"/>
        </joint>

        <joint name="base_to_caster_wheel_1" type="fixed">
            <parent link="base_link"/>
            <child link="caster_wheel_1_standoff_link"/>
            <origin xyz="${base_length/3.0} 0 ${0.025 + base_height}" rpy="0 0 0"/>
        </joint>
        
        <joint name="floor1_to_right_wheel_2" type="fixed">
            <parent link="floor1_link"/>
            <child link="right_wheel_2_standoff_link"/>
            <origin xyz="${-base_length/4.0} ${-(base_width )/3.0} ${0.025 + base_height/2}" rpy="0 0 0"/>
        </joint>

        <joint name="floor1_to_left_wheel_2" type="fixed">
            <parent link="floor1_link"/>
            <child link="left_wheel_2_standoff_link"/>
            <origin xyz="${-base_length/4.0} ${(base_width )/3.0} ${0.025 + base_height/2}" rpy="0 0 0"/>
        </joint>

        <joint name="floor1_to_caster_wheel_2" type="fixed">
            <parent link="floor1_link"/>
            <child link="caster_wheel_2_standoff_link"/>
            <origin xyz="${base_length/3.0} 0 ${0.025 + base_height/2}" rpy="0 0 0"/>
        </joint>
        <!--
        <joint name="floor2_to_right_wheel_3" type="fixed">
            <parent link="floor2_link"/>
            <child link="right_wheel_3_standoff_link"/>
            <origin xyz="0 0 0" rpy="0 0 0"/>
        </joint>

        <joint name="floor2_to_left_wheel_3" type="fixed">
            <parent link="floor2_link"/>
            <child link="left_wheel_3_standoff_link"/>
            <origin xyz="0 0 0" rpy="0 0 0"/>
        </joint>

        <joint name="floor2_to_caster_wheel_3" type="fixed">
            <parent link="floor2_link"/>
            <child link="caster_wheel_3_standoff_link"/>
            <origin xyz="0 0 0" rpy="0 0 0"/>
        </joint>
        -->

        <joint name="base_to_right_wheel" type="continuous">
            <parent link="base_link"/>
            <child link="right_wheel_link"/>
            <origin xyz="${-base_length/4.0} ${-(base_width + wheel_length)/2.0} 0" rpy="0 0 0"/>
            <dynamics damping="1.0" friction="1.0"/>
            <axis xyz="0 1 0"/>
        </joint>

        <joint name="base_to_left_wheel" type="continuous">
            <parent link="base_link"/>
            <child link="left_wheel_link"/>
            <origin xyz="${-base_length/4.0} ${(base_width + wheel_length)/2.0} 0" rpy="0 0 0"/>
            <dynamics damping="1.0" friction="1.0"/>
            <axis xyz="0 1 0"/>
        </joint>

        <joint name="base_to_caster_wheel" type="fixed">
            <parent link="base_link"/>
            <child link="caster_wheel_link"/>
            <origin xyz="${base_length/3.0} 0 ${-wheel_radius/2}" rpy="0 0 0"/>
        </joint>

        
        <joint name="base_to_floor1" type="fixed">
            <parent link="base_link"/>
            <child link="floor1_link"/>
            <origin xyz="0 0 ${wheel_radius + 0.025}" rpy="0 0 0"/>
        </joint>
        
        <joint name="floor1_to_floor2" type="fixed">
            <parent link="floor1_link"/>
            <child link="floor2_link"/>
            <origin xyz="0 0 ${wheel_radius + 0.025}" rpy="0 0 0"/>
        </joint>
        <!--
        <joint name="floor2_to_floor3" type="fixed">
            <parent link="floor2_link"/>
            <child link="floor3_link"/>
            <origin xyz="0 0 0.05" rpy="0 0 0"/>
        </joint>
        -->
        





</robot>